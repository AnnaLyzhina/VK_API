# Токен сообщества VK. Берётся в настройках группы:
# Управление -> Работа с API -> Ключи доступа
TOKEN=your_group_token

# Токен пользователя VK. Нужен для метода users.search и photos.get.
USER_TOKEN=your_user_token

# ID группы VK без слова public или club.
# Например, если группа https://vk.com/public123456789, то GROUP_ID=123456789
GROUP_ID=your_group_id_here

# Версия API VK.
VK_API_VERSION=5.199

# Настройки PostgreSQL
DB_NAME=vk
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432